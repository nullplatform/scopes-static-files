#!/bin/bash

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/get_config_value"

application_slug=$(echo "$CONTEXT" | jq -r .application.slug)
scope_slug=$(echo "$CONTEXT" | jq -r .scope.slug)
namespace_slug=$(echo "$CONTEXT" | jq -r .namespace.slug)
scope_id=$(echo "$CONTEXT" | jq -r .scope.id)
application_version="$(echo "$CONTEXT" | jq -r .release.semver)"
env_vars_json=$(echo "$CONTEXT" | jq '(.parameters.results // []) | map({(.variable): .values[0].value}) | add // {}')

# =============================================================================
# Resolve layer routing from scope-configuration provider
# Priority: provider > env var > (fail)
# =============================================================================
TOFU_PROVIDER=$(get_config_value \
	--provider '.providers["scope-configurations"].cloud_provider' \
	--env TOFU_PROVIDER)

if [ -z "$TOFU_PROVIDER" ]; then
	echo "   ❌ cloud_provider is not configured"
	echo ""
	echo "  💡 Possible causes:"
	echo "    • No scope-configurations provider is attached at this NRN level"
	echo "    • The 'cloud_provider' field is not set in the provider"
	echo ""
	echo "  🔧 How to fix:"
	echo "    • Configure a scope-configurations provider with 'cloud_provider' set to 'aws' or 'azure'"
	echo "    • Or set the TOFU_PROVIDER environment variable"
	exit 1
fi

NETWORK_LAYER=$(get_config_value \
	--provider ".providers[\"scope-configurations\"].network.${TOFU_PROVIDER}_network" \
	--env NETWORK_LAYER)

if [ -z "$NETWORK_LAYER" ]; then
	echo "   ❌ network layer is not configured for provider '$TOFU_PROVIDER'"
	echo ""
	echo "  🔧 How to fix:"
	echo "    • Set 'network.${TOFU_PROVIDER}_network' in the scope-configurations provider"
	echo "    • Or set the NETWORK_LAYER environment variable"
	exit 1
fi

DISTRIBUTION_LAYER=$(get_config_value \
	--provider ".providers[\"scope-configurations\"].distribution.${TOFU_PROVIDER}_distribution" \
	--env DISTRIBUTION_LAYER)

if [ -z "$DISTRIBUTION_LAYER" ]; then
	echo "   ❌ distribution layer is not configured for provider '$TOFU_PROVIDER'"
	echo ""
	echo "  🔧 How to fix:"
	echo "    • Set 'distribution.${TOFU_PROVIDER}_distribution' in the scope-configurations provider"
	echo "    • Or set the DISTRIBUTION_LAYER environment variable"
	exit 1
fi

echo "   ✅ cloud_provider=$TOFU_PROVIDER"
echo "   ✅ network_layer=$NETWORK_LAYER"
echo "   ✅ distribution_layer=$DISTRIBUTION_LAYER"

# =============================================================================
# Security layer (optional)
# When ${TOFU_PROVIDER}_security == "waf", an existing WAFv2 WebACL is attached
# to the distribution. The WebACL name must be provided in the same provider.
# =============================================================================
SECURITY_LAYER=$(get_config_value \
	--provider ".providers[\"scope-configurations\"].security.${TOFU_PROVIDER}_security" \
	--env SECURITY_LAYER)

DISTRIBUTION_WEB_ACL_NAME=""

if [ "$SECURITY_LAYER" = "waf" ]; then
	DISTRIBUTION_WEB_ACL_NAME=$(get_config_value \
		--provider '.providers["scope-configurations"].security.aws_web_acl_name' \
		--env DISTRIBUTION_WEB_ACL_NAME)

	if [ -z "$DISTRIBUTION_WEB_ACL_NAME" ]; then
		echo ""
		echo "   ❌ security layer is set to 'waf' but no WebACL name was provided"
		echo ""
		echo "  🔧 How to fix:"
		echo "    • Set 'security.aws_web_acl_name' in the scope-configurations provider"
		echo "    • Or change 'security.${TOFU_PROVIDER}_security' to 'none'"
		exit 1
	fi
	echo "   ✅ security_layer=waf web_acl_name=$DISTRIBUTION_WEB_ACL_NAME"
else
	echo "   ✅ security_layer=none"
fi

RESOURCE_TAGS_JSON=$(echo "$CONTEXT" | jq \
	'{
	nullplatform: "true",
	account: .account.slug,
	account_id: .account.id,
	namespace: .namespace.slug,
	namespace_id: .namespace.id,
	application: .application.slug,
	application_id: .application.id,
	scope: .scope.slug,
	scope_id: .scope.id,
	deployment_id: .deployment.id
	}')

TOFU_VARIABLES={}

tf_state_key="nullplatform/scopes/static-files/$namespace_slug/$application_slug/$scope_slug-$scope_id"

TOFU_INIT_VARIABLES="${TOFU_INIT_VARIABLES:-} -backend-config=key=$tf_state_key"

TOFU_MODULE_DIR="$SERVICE_PATH/output/$scope_id"
if [ -n "${NP_OUTPUT_DIR:-}" ]; then
	TOFU_MODULE_DIR="$NP_OUTPUT_DIR/output/$scope_id"
fi

mkdir -p "$TOFU_MODULE_DIR"

# =============================================================================
# Modules to compose (comma-separated list)
# Initialized from CUSTOM_MODULES, extended by setup scripts
# =============================================================================
MODULES_TO_USE="${CUSTOM_TOFU_MODULES:-}"

export TOFU_PROVIDER
export NETWORK_LAYER
export DISTRIBUTION_LAYER
export SECURITY_LAYER
export DISTRIBUTION_WEB_ACL_NAME
export TOFU_VARIABLES
export TOFU_INIT_VARIABLES
export TOFU_MODULE_DIR
export MODULES_TO_USE
export RESOURCE_TAGS_JSON