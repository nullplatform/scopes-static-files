#!/bin/bash
# =============================================================================
# Manage S3 Bucket Policy
#
# Adds or removes a CloudFront distribution statement from the shared S3 bucket
# policy without affecting statements from other distributions.
#
# On apply:  runs AFTER tofu  — reads distribution_id from tofu output, adds statement
# On destroy: runs BEFORE tofu — reads distribution_id from tofu output, removes statement
#
# Each statement uses a unique Sid (AllowCF-{distribution_id}) so multiple
# distributions can safely share the same bucket.
#
# Environment variables:
#   TOFU_ACTION     - "apply" to add statement, "destroy" to remove it
#   TOFU_MODULE_DIR - Directory with tofu state (to read outputs)
#   TOFU_VARIABLES  - JSON with distribution_bucket_name
# =============================================================================

set -euo pipefail

# Only applies to CloudFront (AWS). Skip for other providers.
if [[ "${TOFU_PROVIDER:-}" != "aws" ]]; then
  exit 0
fi

# Resolve tofu command
if command -v mise &>/dev/null && mise which tofu &>/dev/null; then
  TOFU_CMD="mise exec -- tofu"
else
  TOFU_CMD="tofu"
fi

bucket_name=$(echo "$TOFU_VARIABLES" | jq -r '.distribution_bucket_name // empty')
if [ -z "$bucket_name" ]; then
  echo "   ⚠️  Could not determine bucket name, skipping bucket policy management"
  exit 0
fi

bucket_arn="arn:aws:s3:::${bucket_name}"

# Read distribution_id from tofu state (available on both apply and pre-destroy)
distribution_id=$($TOFU_CMD -chdir="$TOFU_MODULE_DIR" output -raw distribution_cloudfront_distribution_id 2>/dev/null || echo "")

if [ -z "$distribution_id" ]; then
  echo "   ⚠️  Could not determine distribution ID from tofu state, skipping bucket policy management"
  exit 0
fi

account_id=$(aws sts get-caller-identity --query Account --output text)
distribution_arn="arn:aws:cloudfront::${account_id}:distribution/${distribution_id}"
statement_sid="AllowCF-${distribution_id}"

echo "🔒 Managing bucket policy for: $bucket_name"
echo "   Distribution: $distribution_id"
echo "   Action: $TOFU_ACTION"

# Read current bucket policy (empty if none exists)
current_policy=$(aws s3api get-bucket-policy --bucket "$bucket_name" --query Policy --output text 2>/dev/null || echo "")

if [ -z "$current_policy" ] || [ "$current_policy" = "None" ]; then
  current_policy='{"Version":"2012-10-17","Statement":[]}'
fi

if [ "$TOFU_ACTION" = "apply" ]; then
  # Upsert: remove existing statement with same Sid, then add updated one
  new_policy=$(echo "$current_policy" | jq \
    --arg sid "$statement_sid" \
    --arg bucket_arn "$bucket_arn" \
    --arg dist_arn "$distribution_arn" \
    '
    .Statement = ([.Statement[] | select(.Sid != $sid)] + [
      {
        Sid: $sid,
        Effect: "Allow",
        Principal: { Service: "cloudfront.amazonaws.com" },
        Action: "s3:GetObject",
        Resource: ($bucket_arn + "/*"),
        Condition: {
          StringEquals: {
            "AWS:SourceArn": $dist_arn
          }
        }
      }
    ])
    ')

  aws s3api put-bucket-policy --bucket "$bucket_name" --policy "$new_policy"
  echo "   ✅ Added bucket policy statement for distribution $distribution_id"

elif [ "$TOFU_ACTION" = "destroy" ]; then
  # Remove only our statement
  new_policy=$(echo "$current_policy" | jq \
    --arg sid "$statement_sid" \
    '.Statement = [.Statement[] | select(.Sid != $sid)]')

  statement_count=$(echo "$new_policy" | jq '.Statement | length')

  if [ "$statement_count" -eq 0 ]; then
    aws s3api delete-bucket-policy --bucket "$bucket_name"
    echo "   ✅ Removed bucket policy (no remaining distributions)"
  else
    aws s3api put-bucket-policy --bucket "$bucket_name" --policy "$new_policy"
    echo "   ✅ Removed statement for distribution $distribution_id ($statement_count remaining)"
  fi
fi
