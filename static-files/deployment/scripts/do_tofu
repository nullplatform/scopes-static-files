#!/bin/bash

set -eou pipefail

TOFU_VAR_FILE="$TOFU_MODULE_DIR/.tfvars.json"
echo "$TOFU_VARIABLES" > "$TOFU_VAR_FILE"

CURRENT_DIR=$(dirname "${BASH_SOURCE[0]}")

cd "$CURRENT_DIR"

# Resolve tofu command: use mise if available, otherwise direct tofu
if command -v mise &>/dev/null; then
	if ! mise which tofu &>/dev/null; then
		echo "OpenTofu not found in mise. Installing globally..."
		mise use --global --yes opentofu
	fi
	TOFU_CMD="mise exec -- tofu"
else
	TOFU_CMD="tofu"
fi

# TOFU_INIT_VARIABLES intentionally unquoted: contains multiple -backend-config flags
$TOFU_CMD -chdir="$TOFU_MODULE_DIR" init -input=false $TOFU_INIT_VARIABLES
$TOFU_CMD -chdir="$TOFU_MODULE_DIR" "$TOFU_ACTION" -auto-approve -var-file="$TOFU_VAR_FILE"
